<mujoco model="panda_scene">
  <compiler angle="radian" meshdir="/opt/conda/lib/python3.10/site-packages/robosuite/models/assets"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="512"/>
    <texture name="texplane" type="2d" builtin="checker" rgb1=".2 .3 .4" rgb2=".1 .15 .2"
             width="512" height="512" mark="none"/>
    <material name="matplane" reflectance="0.3" texture="texplane" texrepeat="1 1" texuniform="true"/>
    <texture name="tex-table" type="2d" builtin="flat" rgb1="0.6 0.5 0.4" rgb2="0.6 0.5 0.4"
             width="64" height="64"/>
    <material name="mat-table" texture="tex-table"/>
  </asset>

  <worldbody>
    <!-- 地面 -->
    <geom name="floor" size="2 2 0.01" type="plane" material="matplane"/>

    <!-- 光照 -->
    <light directional="true" diffuse="0.6 0.6 0.6" specular="0.2 0.2 0.2"
           pos="0.5 0.5 3" dir="-0.5 -0.5 -3"/>

    <!-- 桌子 -->
    <body name="table" pos="0.5 0 0">
      <geom name="table_top" type="box" size="0.5 0.5 0.02" pos="0 0 0.82"
            material="mat-table"/>
      <geom name="table_leg1" type="cylinder" size="0.03 0.8" pos="0.4 0.4 0.4"/>
      <geom name="table_leg2" type="cylinder" size="0.03 0.8" pos="0.4 -0.4 0.4"/>
      <geom name="table_leg3" type="cylinder" size="0.03 0.8" pos="-0.4 0.4 0.4"/>
      <geom name="table_leg4" type="cylinder" size="0.03 0.8" pos="-0.4 -0.4 0.4"/>
    </body>

    <!-- 红色方块 -->
    <body name="red_cube" pos="0.5 0 0.86">
      <freejoint/>
      <geom name="cube_geom" type="box" size="0.025 0.025 0.025"
            rgba="1 0.2 0.2 1" mass="0.1"/>
    </body>

    <!-- Panda 机器人 -->
    <include file="/opt/conda/lib/python3.10/site-packages/robosuite/models/assets/robots/panda/robot.xml"/>
    <include file="/opt/conda/lib/python3.10/site-packages/robosuite/models/assets/grippers/panda_gripper.xml"/>
  </worldbody>

  <actuator>
    <position name="pos_j1" joint="joint1" kp="200" kv="20"/>
    <position name="pos_j2" joint="joint2" kp="200" kv="20"/>
    <position name="pos_j3" joint="joint3" kp="200" kv="20"/>
    <position name="pos_j4" joint="joint4" kp="200" kv="20"/>
    <position name="pos_j5" joint="joint5" kp="200" kv="20"/>
    <position name="pos_j6" joint="joint6" kp="200" kv="20"/>
    <position name="pos_j7" joint="joint7" kp="200" kv="20"/>
  </actuator>

  <camera name="agentview" pos="0.5 -0.6 2.0" xyaxes="1 0 0 0 0.9 0.9"
          fovy="60" resolution="224 224"/>
</mujoco>
